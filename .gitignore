*.log
*.tmp
*.temp
*.bak

# 6) Fichiers d'éditeurs
.vscode/
.idea/

# 7) Fichiers système
.DS_Store
Thumbs.db

# 8) Cache d'outils Python
.pytest_cache/
.mypy_cache/